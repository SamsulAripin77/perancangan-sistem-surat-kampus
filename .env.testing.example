APP_NAME=nusaputra-surat
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://nusaputra-surat.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database TEST khusus — WAJIB berbeda dari DB dev di .env agar
# `php artisan test` & `php artisan migrate:fresh --env=testing` tidak pernah
# mengosongkan database pengembangan. Nama ini harus sama dengan DB_DATABASE
# pada phpunit.xml.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nusaputra-surat-testing
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array

MAIL_MAILER=array
FILESYSTEM_DISK=local
